{
  "expo": {
    "name": "ScreenDoctor",
    "slug": "screen-doctor-app",
    "version": "1.0.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "screendoctorapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/screen-doctor-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.screendoctor.screendoctor",
      "buildNumber": "13",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },

    "web": {
      "output": "static",
      "favicon": "./assets/screen-doctor-icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/screen-doctor-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-0000000000000000~0000000000",
          "iosAppId": "ca-app-pub-6336309514571148~9504957798"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "139ec721-df42-4305-8750-2fab0fcaa561"
      }
    }
  }
}
