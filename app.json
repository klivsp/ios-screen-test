{
  "expo": {
    "name": "ScreenDoctor",
    "slug": "screen-doctor-app",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "screendoctorapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/screen-doctor-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.screendoctor.screendoctor",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/screen-doctor-icon.png"
      },
      "package": "app.screendoctor.screendocto",
      "versionCode": 2
    },
    "web": {
      "output": "static",
      "favicon": "./assets/screen-doctor-icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/screen-doctor-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "139ec721-df42-4305-8750-2fab0fcaa561"
      }
    }
  }
}
