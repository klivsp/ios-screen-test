{
  "expo": {
    "name": "ScreenDoctor",
    "slug": "screen-doctor-app",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "screendoctorapp",
    "userInterfaceStyle": "automatic",
    "platforms": ["ios"],
    "splash": {
      "image": "./assets/screen-doctor-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.screendoctor.screendoctor",
      "buildNumber": "15",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/screen-doctor-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "ScreenDoctor needs camera access to control your flashlight for the Flashlight test.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "139ec721-df42-4305-8750-2fab0fcaa561"
      }
    }
  }
}
